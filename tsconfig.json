{
    "$schema": "https://www.schemastore.org/tsconfig",
    "_version": "24.0.0",
    "compilerOptions": {
        "lib": [
            "es2024",
            "ESNext.Array",
            "ESNext.Collection",
            "ESNext.Error",
            "ESNext.Iterator",
            "ESNext.Promise"
        ],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "target": "es2024",
        "strict": true,
        "skipLibCheck": true,
    }
}