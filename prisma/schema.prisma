// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  BARBEIRO
  RECEPÇÃO
}

model User {
  id           String    @id @default(cuid())
  name         String
  avatar       String?
  matricula    String    @unique
  passwordHash String    @map("password_hash")
  role         Role      @default(RECEPÇÃO)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  equipes      Equipe[]
  tokens       Token[]
  services     Service[]

  @@map("users")
}

enum FunctionsRole {
  MASTER_BARBER
  VISAGISTA
  BARBER_JR
}

enum Status {
  EM_ATENDIMENTO
  DISPONIVEL
  FOLGA
  AUSENTE
}

model Equipe {
  id            String        @id @default(uuid())
  functionsRole FunctionsRole @default(BARBER_JR) @map("functions_role")
  avaliaçao    Float         @map("avaliação")
  status        Status        @default(DISPONIVEL)

  barber       User          @relation(fields: [barberId], references: [id])
  barberId     String        @map("barber_id")
  appointments Appointment[]

  @@map("barbers")
}

enum TokenType {
  PASSWORD_RECOVER
}

model Token {
  id        String    @id @default(uuid())
  type      TokenType
  createdAt DateTime  @default(now()) @map("created_At")

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  @@map("tokens")
}

model Service {
  id          String @id @default(uuid())
  title       String
  service     String @map("service")
  description String
  price       Int
  minute      Int

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @map("user_id")

  appointments Appointment[]

  @@map("services")
}

model Appointment {
  id          String   @id @default(uuid())
  clientName  String   @map("client_name")
  phone       String
  description String
  scheduleAt  DateTime

  barber   Equipe @relation(fields: [barberId], references: [id])
  barberId String @map("barber_id")

  service   Service @relation(fields: [serviceId], references: [id])
  serviceId String  @map("service_id")

  @@map("appointments")
}
